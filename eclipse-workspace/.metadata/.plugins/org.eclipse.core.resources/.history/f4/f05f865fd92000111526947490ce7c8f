package sit707_week2;

import java.util.concurrent.TimeUnit;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.chrome.ChromeDriver;

public class SeleniumOperations {

	public static void sleep(int sec) {
		try {
			Thread.sleep(sec * 1000);
		} catch (InterruptedException e) {
			e.printStackTrace();
		}
	}

	public static void officeworks_registration_page(String url) {

		System.out.println("Step 1: Creating driver");
		WebDriver driver = new ChromeDriver();

		System.out.println("Step 2: Maximizing window");
		driver.manage().window().maximize();

		System.out.println("Step 3: Setting wait");
		driver.manage().timeouts().implicitlyWait(10, TimeUnit.SECONDS);

		System.out.println("Step 4: Opening website");
		driver.get(url);

		System.out.println("Step 5: Website opened");
		sleep(2);

		System.out.println("Step 6: Filling first name");
		driver.findElement(By.id("firstname")).sendKeys("Naman");

		System.out.println("Step 7: Filling last name");
		driver.findElement(By.id("lastname")).sendKeys("Dhankhar");

		System.out.println("Step 8: Filling phone number");
		driver.findElement(By.id("phoneNumber")).sendKeys("0412345678");

		System.out.println("Step 9: Filling email");
		driver.findElement(By.id("email")).sendKeys("naman.test123@gmail.com");

		System.out.println("Step 10: Filling password (weak intentionally)");
		driver.findElement(By.id("password")).sendKeys("abc");

		System.out.println("Step 11: Filling confirm password");
		driver.findElement(By.id("confirmPassword")).sendKeys("abc");

		System.out.println("Step 12: Clicking create account");
		driver.findElement(By.cssSelector("button[data-testid='account-action-btn']")).click();

		System.out.println("Step 13: Waiting for validation result");
		sleep(10); // gives you time to see result or take screenshot

		System.out.println("Step 14: Closing browser");
		driver.close();
	}
}